DB_URL=jdbc:postgresql://localhost:5432/poscloud
DB_USERNAME=
DB_PASSWORD=
CORS_ALLOWED_ORIGINS=http://localhost:1207

# Cookie 是否加 Secure 屬性：本機純 http 開發設 false，正式環境（HTTPS）設 true
COOKIE_SECURE=false

# Docker 啟動 app 容器時連本機 Postgres 用的 URL（docker-compose 會覆蓋 DB_URL）
DOCKER_DB_URL=jdbc:postgresql://host.docker.internal:5432/poscloud
